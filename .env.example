# ===========================================
# PostgreSQL credentials
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sos_dev

# ===========================================
# Authentication
# Generate: openssl rand -base64 32
# ===========================================
JWT_SECRET=generate-with-openssl-rand-base64-32

# ===========================================
# Exposed ports on host (Docker Compose)
# ===========================================
APP_PORT=3000
DB_PORT=5432  # host port from compose.override.yaml — must match the port in DATABASE_URL below

# ===========================================
# Local development without Docker
# (used by Prisma CLI and Next.js directly)
# Keep the port here in sync with DB_PORT above.
# ===========================================
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/sos_dev
DATABASE_URL_TEST=postgresql://postgres:change_me@localhost:5432/sos_test
